  },
  "curl_examples": {
    "test_eligible_scope": {
      "command": "curl -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"query\": \"Can I use the chatbot here?\", \"user_role\": \"researcher\", \"chat_type\": \"open_chat\", \"request_stage\": \"draft_revision\"}'",
      "description": "Test eligible chat scope"
    },
    "test_ineligible_chat": {
      "command": "curl -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"query\": \"Can I use the chatbot here?\", \"user_role\": \"researcher\", \"chat_type\": \"contributors_chat\", \"request_stage\": \"draft_revision\"}'",
      "description": "Test ineligible chat type"
    },
    "test_ineligible_stage": {
      "command": "curl -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"query\": \"Can I use the chatbot here?\", \"user_role\": \"researcher\", \"chat_type\": \"open_chat\", \"request_stage\": \"approved\"}'",
      "description": "Test ineligible request stage"
    },
    "test_form_check_stage": {
      "command": "curl -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"query\": \"Is this valid?\", \"user_role\": \"researcher\", \"chat_type\": \"open_chat\", \"request_stage\": \"form_check\"}'",
      "description": "Test form-check stage (eligible)"
    },
    "test_missing_chat_type": {
      "command": "curl -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"query\": \"Can I use the chatbot?\", \"user_role\": \"researcher\", \"request_stage\": \"draft_revision\"}'",
      "description": "Test missing chat_type (defaults to open_chat)"
    },
    "test_missing_stage": {
      "command": "curl -X POST http://localhost:8000/chat -H 'Content-Type: application/json' -d '{\"query\": \"Can I use the chatbot?\", \"user_role\": \"researcher\", \"chat_type\": \"open_chat\"}'",
      "description": "Test missing request_stage (defaults to draft_revision)"
    }
  },
  "validation_rules": {
    "RULE_1": {
      "description": "Check chat type is eligible (open_chat only)",
      "allowed_values": ["open_chat"],
      "blocked_values": ["contributors_chat", "requestor_chat", "private_org_chat"]
    },
    "RULE_2": {
      "description": "Check request stage is draft/revision or form-check",
      "allowed_values": ["draft_revision", "form_check"],
      "blocked_values": ["submitted", "approved", "rejected"]
    },
    "RULE_3": {
      "description": "Verify chat is not in other channels",
      "priority": "before stage check",
      "error_message": "This feature is only available in the open chat for your data request."
    },
    "RULE_4": {
      "description": "Verify request hasn't passed form-check validation stage",
      "priority": "after chat check",
      "error_message": "Form-check has been completed. Please contact support for further assistance."
    }
  },
  "error_scenarios": {
    "ERROR_1_WRONG_CHAT_TYPE": {
      "message": "This feature is only available in the open chat for your data request.",
      "triggers": ["contributors_chat", "requestor_chat", "private_org_chat"],
      "priority": 1
    },
    "ERROR_2_WRONG_STAGE": {
      "message": "This feature is only available during the form-check stage of your request.",
      "triggers": ["submitted", "unknown_stage", ""],
      "priority": 2
    },
    "ERROR_3_STAGE_COMPLETED": {
      "message": "Form-check has been completed. Please contact support for further assistance.",
      "triggers": ["approved", "rejected"],
      "priority": 2
    },
    "ERROR_4_CHAT_NOT_FOUND": {
      "message": "Unable to verify chat context. Please try again.",
      "triggers": ["null", "unknown_chat_type"],
      "priority": 1
    }
  },
  "statistics": {
    "total_queries": 23,
    "eligible_queries": 5,
    "ineligible_queries": 13,
    "combined_ineligible_queries": 3,
    "edge_case_queries": 9,
    "categories": 5,
    "allowed_chat_types": 1,
    "blocked_chat_types": 3,
    "allowed_stages": 2,
    "blocked_stages": 3
  },
  "execution_order": {
    "step_1": "Validate chat_type FIRST (Rule 1 - check RULE_1)",
    "step_2": "Validate request_stage SECOND (Rule 2 - check RULE_2)",
    "step_3": "Return error_message based on what failed",
    "note": "Chat type validation takes priority - always check chat before stage"
  }
}
