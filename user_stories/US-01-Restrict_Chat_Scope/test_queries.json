          "user_role": "researcher",
          "query": "How do I submit?",
          "expected_status": "failed",
          "expected_error": "unknown_chat_type",
          "description": "Null chat_type in request"
        },
        {
          "id": "edge_003",
          "chat_type": "open_chat",
          "request_stage": "",
          "user_role": "researcher",
          "query": "How do I submit?",
          "expected_status": "failed",
          "expected_error": "wrong_stage",
          "description": "Empty request_stage string"
        },
        {
          "id": "edge_004",
          "chat_type": "open_chat",
          "request_stage": null,
          "user_role": "researcher",
          "query": "How do I submit?",
          "expected_status": "failed",
