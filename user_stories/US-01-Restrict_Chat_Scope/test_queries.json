{
  "description": "Test queries for US-01: Restrict Chat Scope to Eligible Chats and Stages",
  "version": "1.0",
  "last_updated": "2026-07-03",
  "usage": "Use these queries to test chat scope validation with curl or automated test scripts",
  "endpoint": "POST /chat",
  "categories": {
    "ELIGIBLE_SCOPES": {
      "description": "Queries from eligible chats and stages - should PASS scope validation",
      "expected_response": "validation_status: passed, scope check succeeded",
      "tests": [
        {
          "id": "eligible_001",
          "chat_type": "open_chat",
          "request_stage": "draft_revision",
          "user_role": "researcher",
          "query": "Can I use the chatbot in the open chat during the draft stage?",
          "expected_status": "passed",
          "description": "Open chat during draft_revision stage"
        },
        {
          "id": "eligible_002",
          "chat_type": "open_chat",
          "request_stage": "form_check",
          "user_role": "researcher",
          "query": "What is the form check process?",
          "expected_status": "passed",
          "description": "Open chat during form_check stage"
        },
        {
          "id": "eligible_003",
          "chat_type": "open_chat",
          "request_stage": "draft_revision",
          "user_role": "team_member",
          "query": "How do I submit a data request?",
          "expected_status": "passed",
          "description": "Team member in open chat, draft stage"
        },
        {
          "id": "eligible_004",
          "chat_type": "open_chat",
          "request_stage": "form_check",
          "user_role": "data_request_creator",
          "query": "Can I modify my submission?",
          "expected_status": "passed",
          "description": "Data request creator in open chat, form-check stage"
        },
        {
          "id": "eligible_005",
          "chat_type": "open_chat",
          "request_stage": "draft_revision",
          "user_role": "research_team_admin",
          "query": "What are the requirements?",
          "expected_status": "passed",
          "description": "Research team admin in open chat, draft stage"
        }
      ]
    },
    "INELIGIBLE_CHATS": {
      "description": "Queries from blocked chat types - should FAIL scope validation",
      "expected_response": "validation_status: failed, error: 'open chat only' message",
      "tests": [
        {
          "id": "ineligible_chat_001",
          "chat_type": "contributors_chat",
          "request_stage": "draft_revision",
          "user_role": "researcher",
          "query": "How do I submit a data request?",
          "expected_status": "failed",
          "expected_error": "wrong_chat_type",
          "description": "Blocked: Contributors chat"
        },
        {
          "id": "ineligible_chat_002",
          "chat_type": "requestor_chat",
          "request_stage": "draft_revision",
          "user_role": "researcher",
          "query": "What is the data request?",
          "expected_status": "failed",
          "expected_error": "wrong_chat_type",
          "description": "Blocked: Requestor chat"
        },
        {
          "id": "ineligible_chat_003",
          "chat_type": "private_org_chat",
          "request_stage": "draft_revision",
          "user_role": "researcher",
          "query": "Tell me about requests",
          "expected_status": "failed",
          "expected_error": "wrong_chat_type",
          "description": "Blocked: Private org chat"
        },
        {
          "id": "ineligible_chat_004",
          "chat_type": "requestor_chat",
          "request_stage": "form_check",
          "user_role": "team_member",
          "query": "Can I help?",
          "expected_status": "failed",
          "expected_error": "wrong_chat_type",
          "description": "Blocked: Requestor chat during form-check"
        },
        {
          "id": "ineligible_chat_005",
          "chat_type": "private_org_chat",
          "request_stage": "form_check",
          "user_role": "data_request_creator",
          "query": "Status update",
          "expected_status": "failed",
          "expected_error": "wrong_chat_type",
          "description": "Blocked: Private org chat during form-check"
        }
      ]
    },
    "INELIGIBLE_STAGES": {
      "description": "Queries from ineligible request stages - should FAIL scope validation",
      "expected_response": "validation_status: failed, error: 'form-check stage only' or 'completed' message",
      "tests": [
        {
          "id": "ineligible_stage_001",
          "chat_type": "open_chat",
          "request_stage": "submitted",
          "user_role": "researcher",
          "query": "How do I submit a data request?",
          "expected_status": "failed",
          "expected_error": "wrong_stage",
          "description": "Blocked: submitted stage (form-check not completed)"
        },
        {
          "id": "ineligible_stage_002",
          "chat_type": "open_chat",
          "request_stage": "approved",
          "user_role": "researcher",
          "query": "When will I get access?",
          "expected_status": "failed",
          "expected_error": "stage_completed",
          "description": "Blocked: approved stage (request completed)"
        },
        {
          "id": "ineligible_stage_003",
          "chat_type": "open_chat",
          "request_stage": "rejected",
          "user_role": "team_member",
          "query": "Can I resubmit?",
          "expected_status": "failed",
          "expected_error": "stage_completed",
          "description": "Blocked: rejected stage (request completed)"
        },
        {
          "id": "ineligible_stage_004",
          "chat_type": "open_chat",
          "request_stage": "submitted",
          "user_role": "data_request_creator",
          "query": "What happens next?",
          "expected_status": "failed",
          "expected_error": "wrong_stage",
          "description": "Blocked: submitted - human review in progress"
        },
        {
          "id": "ineligible_stage_005",
          "chat_type": "open_chat",
          "request_stage": "approved",
          "user_role": "research_team_admin",
          "query": "Access granted?",
          "expected_status": "failed",
          "expected_error": "stage_completed",
          "description": "Blocked: approved - request finalized"
        }
      ]
    },
    "COMBINED_INELIGIBLE": {
      "description": "Queries with both wrong chat AND wrong stage - should FAIL on chat type first",
      "expected_response": "validation_status: failed, error: 'open chat only' message (chat checked first)",
      "tests": [
        {
          "id": "combined_001",
          "chat_type": "contributors_chat",
          "request_stage": "submitted",
          "user_role": "researcher",
          "query": "Query",
          "expected_status": "failed",
          "expected_error": "wrong_chat_type",
          "description": "Both invalid: chat type checked first"
        },
        {
          "id": "combined_002",
          "chat_type": "requestor_chat",
          "request_stage": "approved",
          "user_role": "team_member",
          "query": "Query",
          "expected_status": "failed",
          "expected_error": "wrong_chat_type",
          "description": "Both invalid: returns chat error"
        },
        {
          "id": "combined_003",
          "chat_type": "private_org_chat",
          "request_stage": "rejected",
          "user_role": "data_request_creator",
          "query": "Query",
          "expected_status": "failed",
          "expected_error": "wrong_chat_type",
          "description": "Both invalid: prioritizes chat validation"
        }
      ]
    },
