# ============================================================
# VIVLI RAG CHATBOT - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env to Git - it contains sensitive credentials!
# This .env.example is for reference only
#
# To set up:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your Azure credentials
# 3. Add .env to .gitignore (already done)
# 4. Never commit .env!

# ============================================================
# AZURE OPENAI
# ============================================================
# Get these from Azure Portal > Cognitive Services > Your OpenAI Resource

AZURE_OPENAI_API_KEY="your-azure-openai-api-key-here"
# Format: Long alphanumeric string from Azure Portal

AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# Format: https://[resource-name].openai.azure.com/
# Example: https://ascendion-resource.openai.azure.com/

AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Standard API version for current Azure OpenAI

# ============================================================
# AZURE OPENAI DEPLOYMENTS
# ============================================================
# These are the model deployments you created in Azure
# Must match exactly what you deployed in Azure Portal

AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large
# Deployment name for embedding model
# Used for generating vectors from text

AZURE_OPENAI_DEPLOYMENT_LLM=gpt-4o-mini
# Deployment name for language model
# Used for generating chat responses

# ============================================================
# AZURE AI SEARCH
# ============================================================
# Get these from Azure Portal > Search Services > Your Search Service

AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
# Format: https://[service-name].search.windows.net
# Example: https://vivli-demo-cus-srch.search.windows.net

AZURE_SEARCH_ADMIN_KEY="your-azure-search-admin-key-here"
# Format: Long alphanumeric string
# WARNING: This is an admin key - keep it private!

AZURE_SEARCH_INDEX_NAME=vivli-knowledge-base
# Name of the index in Azure AI Search
# Used for storing documents and enabling search

# ============================================================
# APPLICATION SETTINGS
# ============================================================

DEBUG=False
# Set to True only for local development
# NEVER True in production!

LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# INFO is recommended for production
# DEBUG for development and troubleshooting

# ============================================================
# OPTIONAL: INGESTION SETTINGS
# ============================================================
# These can also be passed as command-line arguments

# EMBEDDING_BATCH_SIZE=10
# Number of chunks to embed per batch before pausing
# Increase for faster ingestion (higher error risk)
# Decrease for safer ingestion (slower)

# BATCH_DELAY_SECONDS=1.0
# Seconds to wait between embedding batches
# Prevents hitting Azure API rate limits (429 errors)
# Increase if getting 429 errors
# Decrease for faster ingestion (if no errors)

# ============================================================
# HOW TO USE
# ============================================================
# 1. Fill in all the values above with your Azure credentials
# 2. Save as .env (not .env.example)
# 3. Keep .env private - never commit to Git!
# 4. The app will load these variables at startup

# ============================================================
# WHERE TO GET CREDENTIALS
# ============================================================
#
# AZURE OPENAI KEYS:
#   1. Go to https://portal.azure.com/
#   2. Find your OpenAI resource
#   3. Click "Keys and Endpoint" in the left menu
#   4. Copy "Key 1" and "Endpoint"
#   5. Deployment names are in "Deployments" section
#
# AZURE SEARCH KEYS:
#   1. Go to https://portal.azure.com/
#   2. Find your Search Service
#   3. Click "Keys" in the left menu
#   4. Copy the "Primary admin key"
#   5. Endpoint is displayed at the top
#   6. Index name is what you created in Search Explorer
#
# ============================================================
# SECURITY NOTES
# ============================================================
#
# ⚠️  NEVER share these values!
# ⚠️  NEVER commit .env to Git!
# ⚠️  NEVER put credentials in source code!
# ⚠️  Rotate keys regularly!
#
# If credentials are leaked:
#   1. Go to Azure Portal immediately
#   2. Regenerate all keys
#   3. Update this .env file
#   4. Restart the application
#
# ============================================================
# EXAMPLE VALUES (NOT REAL)
# ============================================================
# These are examples of what values should look like:
#
# AZURE_OPENAI_API_KEY="6TnS2NNUSUvaUfkN1sIRP52Q94Zl7S6e..."
# AZURE_OPENAI_ENDPOINT=https://my-openai-resource.openai.azure.com/
# AZURE_SEARCH_ENDPOINT=https://my-search-service.search.windows.net
# AZURE_SEARCH_ADMIN_KEY="yP2yPiwPR62cBZTg4Fr495kfRttZIZem..."
#
# ============================================================
